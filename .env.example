# OAuth 2.0 credentials for importing the user's YouTube library (Likes,
# Subscriptions, Playlists). Obtain these from https://console.cloud.google.com/
# — see "YouTube OAuth" in RUNBOOK.md for exact setup (enable YouTube Data API
# v3, create a Web application OAuth Client ID, register the loopback redirect
# URI http://localhost:6060/api/youtube/oauth/callback).
YOUTUBE_OAUTH_CLIENT_ID=
YOUTUBE_OAUTH_CLIENT_SECRET=

# Optional. Max number of most-recent uploads to import per subscribed channel
# on each Subscriptions import. Defaults to 25.
# YOUTUBE_SUBSCRIPTION_UPLOAD_LIMIT=25

# --- Taste substrate ---
# Used by scripts/taste/*. See RUNBOOK "Taste substrate" for setup.

# Which embedding provider to use. Options: openai | bge-local.
# Default: openai. `bge-local` routes to Ollama's /api/embeddings endpoint.
# EMBEDDING_PROVIDER=openai

# OpenAI API key. Required only if EMBEDDING_PROVIDER=openai (default).
# Used exclusively for embeddings (text-embedding-3-small). Full corpus
# rebuild for ~5,665 videos is ~$0.30 at current pricing.
OPENAI_API_KEY=

# Ollama base URL. Used for local enrichment (always) and for `bge-local`
# embeddings if selected. Defaults to the stock install.
# OLLAMA_HOST=http://localhost:11434

# Which local model Ollama uses for enrichment. Pick one you have pulled
# (`ollama list` to check). A small model is fine — this is a ~50-word
# summary + 3 tags, not a reasoning task.
# OLLAMA_ENRICHMENT_MODEL=gemma3:4b

# --- Editor agent (phase 3) ---
# See RUNBOOK "Editor agent".

# Anthropic API key. Required for the editor agent at `/`. Without it the
# chat panel renders a disabled card and the slot board remains fully usable.
ANTHROPIC_API_KEY=

# Which Claude model to use. Default claude-sonnet-4-6; set to
# claude-opus-4-7 for harder composition sessions (higher cost).
# AGENT_MODEL=claude-sonnet-4-6

# Cap on tool-use loop iterations per user message. Default 10.
# AGENT_MAX_TURNS=10

# --- Overnight maintenance (phase 5) ---
# See RUNBOOK "Overnight maintenance".

# Hour (0–23, local time) at which the launchd agent fires the nightly
# pipeline. Only read by `just nightly-install` when it templates the plist;
# editing this after installing requires re-running `just nightly-install`.
# NIGHTLY_HOUR=3

# Score floor for the description-graph. Candidates scoring below this are
# dropped pre-insert into discovery_candidates. Range 0–2 (cluster weight is
# clamped to [0, 2]); default 0.55 is empirically the "below this you get
# 10× more noise" line on OpenAI text-embedding-3-small.
# DISCOVERY_FUZZY_FLOOR=0.55

# Centroid-drift threshold that flips step 6 (recluster) from incremental
# update to a full rebuild. Drift is 1 - cosine(old_centroid, new_centroid).
# Default 0.20 ≈ "the taste cluster genuinely shifted".
# RECLUSTER_REBUILD_DRIFT=0.20
