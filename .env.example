# Optional. YouTube Data API v3 key. Currently unused for ingestion (RSS is the
# primary path) — reserved for future use if we ever need richer metadata.
YOUTUBE_API_KEY=

# OAuth 2.0 credentials for importing the user's YouTube subscriptions.
# Obtain these from https://console.cloud.google.com/ — see "YouTube OAuth"
# in RUNBOOK.md for the exact setup steps (Google Cloud project, YouTube
# Data API v3, OAuth consent screen, loopback redirect URI).
YOUTUBE_OAUTH_CLIENT_ID=
YOUTUBE_OAUTH_CLIENT_SECRET=
